# qwen-baseline-eval / config.env  (cloud — DashScope + public ECR)
#
# Copy this file to config.env and fill in the required values.
#   cp config.env.example config.env
#
# Required: DASHSCOPE_API_KEY, DASHSCOPE_WORKSPACE_ID (if region is Singapore/HK/EU)
# Everything else has a sensible default.

# ---------------------------------------------------------------------------
# DashScope (Alibaba Cloud) — OpenAI-compatible inference endpoint
# ---------------------------------------------------------------------------
# Region selects the base URL automatically (see lib.sh:resolve_dashscope_base_url).
# Override DASHSCOPE_BASE_URL below if you need a non-default URL.
DASHSCOPE_REGION=ap-southeast-1
DASHSCOPE_WORKSPACE_ID=                      # required for Singapore / HK / Frankfurt
DASHSCOPE_API_KEY=                           # paste your key here (or `export` it before running)
# DASHSCOPE_BASE_URL=                        # uncomment + set to override the derived URL

# ---------------------------------------------------------------------------
# Model
# ---------------------------------------------------------------------------
MODEL_NAME=qwen3.7-max
MODEL_ID=qwen3.7-max
MAX_MODEL_LEN=131072                         # advertised to litellm (Terminus-2 trims history to fit)

# ---------------------------------------------------------------------------
# TerminalBench
# ---------------------------------------------------------------------------
TERMINALBENCH_DATASET=terminal-bench
TERMINALBENCH_VERSION=2.0
TERMINALBENCH_WORKERS=4
TB_VENV_DIR=$HOME/tb_venv
TB_VERSION=0.2.18
TB_AGENT=terminus-2
TB_PARSER=xml

# ---------------------------------------------------------------------------
# TerminalBench-2 image source (public ECR mirror)
# ---------------------------------------------------------------------------
TB_PUBLIC_ECR=public.ecr.aws/l7z4o9j8/holboxai/terminal-bench-2
TB_TAG_PREFIX=                               # match what you used when mirroring (e.g. tb2.)
TB2_REPO_URL=https://github.com/laude-institute/terminal-bench-2.git
TB2_REF=main
TB2_WORK_DIR=$HOME/terminal-bench-2-src
TASK_FILTER=                                 # regex; leave blank to include all tasks
PULL_WORKERS=4

# ---------------------------------------------------------------------------
# Output / housekeeping
# ---------------------------------------------------------------------------
RESULTS_DIR=$HOME/baseline-results
S3_RESULTS_URI=                              # e.g. s3://my-bucket/baseline (optional)
EVAL_VENV_DIR=$HOME/eval_venv
PY_VERSION=3.12
